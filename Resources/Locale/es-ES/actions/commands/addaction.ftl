# addaction
cmd-addaction-desc = Añade una acción a la entidad objetivo. La acción no funcionará si el objetivo requiere un componente adicional en su entidad (como Devorar del Dragón).
cmd-addaction-help = addaction <EntityUid> <ActionPrototype>

cmd-addaction-invalid-args = Se esperaban exactamente 2 argumentos.
cmd-addaction-actions-not-found = La entidad objetivo no puede usar acciones.
cmd-addaction-action-not-found = No se puede encontrar el prototipo de acción correspondiente {$action}.
cmd-addaction-adding-failed = No se pudo añadir la acción.

cmd-addaction-player-completion = <EntityUid>
cmd-addaction-action-completion = <ActionProto>
