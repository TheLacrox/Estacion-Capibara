### UI

# Shown when examining the window. Each entry represents the window's health condition
comp-window-damaged-1 = Parece completamente intacta.
comp-window-damaged-2 = Tiene algunos arañazos.
comp-window-damaged-3 = Tiene algunas grietas pequeñas.
comp-window-damaged-4 = [color=yellow]Tiene varias grietas grandes que recorren su superficie.[/color]
comp-window-damaged-5 = [color=orange]Tiene grietas profundas en múltiples capas.[/color]
comp-window-damaged-6 = [color=red]Está extremadamente agrietada y a punto de romperse.[/color]

### Interaction Messages

# Shown when knocking on a window
comp-window-knock = *toc toc*
