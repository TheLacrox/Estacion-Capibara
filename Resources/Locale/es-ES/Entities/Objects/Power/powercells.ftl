ent-BasePowerCell = objeto

ent-PowerCellSmallPrinted = pila de baja capacidad
    .desc = Una pila recargable. Es el tipo más barato que puedes encontrar.

ent-PowerCellMediumPrinted = pila de capacidad media
    .desc = Una pila recargable. Es la versión popular y confiable.

ent-PowerCellHighPrinted = pila de alta capacidad
    .desc = Una pila recargable estandarizada. Esta marca premium almacena hasta un 50% más de energía que la competencia.

ent-PowerCellHyperPrinted = pila de hiper capacidad
    .desc = Una pila recargable estandarizada. Esta iteración lleva al límite el almacenamiento portátil de energía, con un 66% más de capacidad que su predecesora.

ent-PowerCellMicroreactorPrinted = pila de microreactor
    .desc = Una pila de microreactor recargable estandarizada. Tiene menor capacidad pero se recarga lentamente por sí sola.

ent-BasePowerCage = objeto

ent-PowerCageSmallEmpty = jaula de energía de baja capacidad
    .desc = Una jaula de energía recargable para dispositivos grandes. Es el tipo más barato que puedes encontrar.

ent-PowerCageMediumEmpty = jaula de energía de capacidad media
    .desc = Una jaula de energía recargable para dispositivos grandes. El estándar de oro en capacidad y costo.

ent-PowerCageHighEmpty = jaula de energía de alta capacidad
    .desc = Una jaula de energía recargable para dispositivos grandes. Mayor capacidad para niveles de potencia más elevados.
