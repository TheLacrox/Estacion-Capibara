cmd-showaccessreaders-desc = Alterna la visualización de permisos de lectores de acceso en el mapa
cmd-showaccessreaders-help =
    Información de superposición:
    -Disabled | El lector de acceso está desactivado
    +Unrestricted | El lector de acceso no tiene restricciones
    +Set [Índice]: [Nombre de etiqueta]| Una etiqueta en un conjunto de acceso (el accesador necesita todas las etiquetas del conjunto para ser permitido)
    +Key [StationUid]: [StationRecordKeyId] | Una StationRecordKey que está permitida
    -Tag [Nombre de etiqueta] | Una etiqueta que no está permitida (tiene prioridad sobre otros permisos)
cmd-showaccessreaders-status = Superposición de depuración de lectores de acceso establecida a {$status}.
