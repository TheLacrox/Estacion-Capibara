cmd-addrole-desc = Añade un rol a la mente de un jugador.
cmd-addrole-help = Uso: addrole <ID de sesión> <rol>
cmd-addrole-mind-not-found = No se puede encontrar esa mente.
cmd-addrole-role-not-found = No se puede encontrar ese rol.
cmd-addrole-mind-already-has-role = La mente ya tiene ese rol.

cmd-listroles-desc = Lista todos los roles disponibles.
cmd-listroles-help = Uso: listroles

cmd-rmrole-desc = Elimina un rol de la mente de un jugador.
cmd-rmrole-help = Uso: rmrole <ID de sesión> <Tipo de rol>
                  El tipo de rol es el nombre de tipo C# real.
