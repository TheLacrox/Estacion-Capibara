signal-linker-component-saved = ¡Enlace guardado correctamente en {$machine}!
signal-linker-component-linked-port = ¡Se enlazó correctamente {$machine1}:{$port1} con {$machine2}:{$port2}!
signal-linker-component-unlinked-port = ¡Se desenlazó correctamente {$machine1}:{$port1} de {$machine2}:{$port2}!
signal-linker-component-connection-refused = ¡{$machine} rechazó la conexión!
signal-linker-component-max-connections-receiver = ¡Se alcanzó el máximo de conexiones en el receptor!
signal-linker-component-max-connections-transmitter = ¡Se alcanzó el máximo de conexiones en el transmisor!

signal-linker-component-type-mismatch = ¡El tipo del puerto no coincide con el tipo del puerto guardado!

signal-linker-component-out-of-range = ¡La conexión está fuera de alcance!

# Verbs
signal-linking-verb-text-link-default = Enlazar puertos predeterminados
signal-linking-verb-success = Se conectaron todos los enlaces predeterminados de {$machine}.
signal-linking-verb-fail = No se pudieron conectar todos los enlaces predeterminados de {$machine}.
signal-linking-verb-disabled-no-transmitter = Primero interactúa con un transmisor y luego enlaza los puertos predeterminados.
signal-linking-verb-disabled-no-receiver = Primero interactúa con un receptor y luego enlaza los puertos predeterminados.
