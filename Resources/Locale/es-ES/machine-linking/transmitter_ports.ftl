signal-port-name-pressed = Presionado
signal-port-description-pressed = Este puerto se invoca cada vez que se activa el transmisor.

signal-port-name-on-transmitter = Encendido
signal-port-description-on-transmitter = Este puerto se invoca cada vez que el transmisor se enciende.

signal-port-name-off-transmitter = Apagado
signal-port-description-off-transmitter = Este puerto se invoca cada vez que el transmisor se apaga.

signal-port-name-status-transmitter = Estado
signal-port-description-status-transmitter = Este puerto se invoca con ALTO o BAJO según el estado del transmisor.

signal-port-name-left = Izquierda
signal-port-description-left = Este puerto se invoca cada vez que la palanca se mueve a la posición más a la izquierda.

signal-port-name-right = Derecha
signal-port-description-right = Este puerto se invoca cada vez que la palanca se mueve a la posición más a la derecha.

signal-port-name-doorstatus = Estado de la puerta
signal-port-description-doorstatus = Este puerto se invoca con ALTO cuando la puerta se abre y BAJO cuando la puerta termina de cerrarse.

signal-port-name-dockstatus = Estado de acoplamiento
signal-port-description-dockstatus = Este puerto se invoca con ALTO cuando está acoplado y BAJO cuando está desacoplado.

signal-port-name-middle = Centro
signal-port-description-middle = Este puerto se invoca cada vez que la palanca se mueve a la posición neutral.

signal-port-name-trigger-sender = Disparador
signal-port-description-trigger-sender = Este puerto se invoca cada vez que el dispositivo se activa.

signal-port-name-timer-trigger = Temporizador
signal-port-description-timer-trigger = Este puerto se invoca cuando se acaba el tiempo del temporizador.

signal-port-name-timer-start = Inicio de Temporizador
signal-port-description-timer-start = Este puerto se invoca cuando el temporizador comienza.

signal-port-name-logic-output = Salida
signal-port-description-logic-output = Este puerto se invoca con ALTO o BAJO dependiendo de la puerta seleccionada y las entradas.

signal-port-name-logic-output-high = Salida Alta
signal-port-description-logic-output-high = Este puerto se invoca cuando la entrada tiene un flanco ascendente.

signal-port-name-logic-output-low = Salida Baja
signal-port-description-logic-output-low = Este puerto se invoca cuando la entrada tiene un flanco descendente.

signal-port-name-air-danger = Peligro
signal-port-description-air-danger = Este puerto se invoca con ALTO cuando está en modo peligro y BAJO cuando no.

signal-port-name-air-warning = Advertencia
signal-port-description-air-warning = Este puerto se invoca con ALTO cuando está en modo advertencia y BAJO cuando no.

signal-port-name-air-normal = Normal
signal-port-description-air-normal = Este puerto se invoca con ALTO cuando está en modo normal y BAJO cuando no.

signal-port-name-decaying = Decayendo
signal-port-description-decaying = Este puerto se invoca cuando una anomalía enlazada comienza a decaer.

signal-port-name-stabilize = Estabilizar
signal-port-description-stabilize = Este puerto se invoca cuando una anomalía enlazada se normaliza.

signal-port-name-growing = Creciendo
signal-port-description-growing = Este puerto se invoca cuando una anomalía enlazada comienza a crecer.

signal-port-name-pulse = Pulso
signal-port-description-pulse = Este puerto se invoca cuando una anomalía enlazada está pulsando.

signal-port-name-supercrit = Supercrítico
signal-port-description-supercrit = Este puerto se invoca cuando una anomalía enlazada explota tras el estado supercrítico.

signal-port-name-power-charging = Cargando
signal-port-description-power-charging = Este puerto se invoca con ALTO cuando la batería está ganando carga y BAJO cuando no.

signal-port-name-power-discharging = Descargando
signal-port-description-power-discharging = Este puerto se invoca con ALTO cuando la batería está perdiendo carga y BAJO cuando no.

signal-port-name-item-detected = Detectado
signal-port-description-item-detected = Este puerto se invoca cada vez que el transmisor detecta un objeto.
