<controls:FancyWindow
    xmlns="https://spacestation14.io"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:gfx="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
    xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
    Title="{Loc 'capibara-salary-console-title'}"
    MinSize="650 520"
    SetSize="720 580">

    <BoxContainer Orientation="Vertical" VerticalExpand="True">

        <!-- Header Info Panel -->
        <BoxContainer Orientation="Vertical" Margin="8 6 8 0">
            <GridContainer Columns="3">
                <!-- Auth Status -->
                <Label Text="{Loc 'capibara-salary-console-header-auth'}"
                       StyleClasses="LabelKeyText" />
                <PanelContainer StyleClasses="LowDivider" Margin="0 -2"/>
                <Label Name="AuthLabel" Margin="4 0"/>

                <!-- Payroll Status -->
                <Label Text="{Loc 'capibara-salary-console-header-payroll'}"
                       StyleClasses="LabelKeyText" />
                <PanelContainer StyleClasses="LowDivider" Margin="0 -2"/>
                <Label Name="PayrollStatusLabel" Margin="4 0"/>
            </GridContainer>
        </BoxContainer>

        <!-- ID Card Controls -->
        <BoxContainer Orientation="Horizontal" Margin="8 6 8 2">
            <Button Name="InsertButton"
                    Text="{Loc 'capibara-salary-console-insert-id'}"
                    StyleClasses="OpenLeft"
                    HorizontalExpand="True" />
            <Button Name="EjectButton"
                    Text="{Loc 'capibara-salary-console-eject-id'}"
                    StyleClasses="OpenRight"
                    HorizontalExpand="True" />
        </BoxContainer>

        <!-- Freeze Warning Banner -->
        <PanelContainer Name="FreezePanel" Margin="8 2" Visible="False">
            <PanelContainer.PanelOverride>
                <gfx:StyleBoxFlat BackgroundColor="#44CC0000" BorderColor="#CC0000"
                                  BorderThickness="1 1 1 1" ContentMarginLeftOverride="6"
                                  ContentMarginTopOverride="4" ContentMarginBottomOverride="4"
                                  ContentMarginRightOverride="6"/>
            </PanelContainer.PanelOverride>
            <Label Name="FreezeWarning"
                   Text="{Loc 'capibara-salary-console-frozen-warning'}"
                   HorizontalAlignment="Center" />
        </PanelContainer>

        <!-- Employee List (scrollable, department-grouped) -->
        <PanelContainer VerticalExpand="True" Margin="8 4 8 0">
            <PanelContainer.PanelOverride>
                <gfx:StyleBoxFlat BackgroundColor="#1B1B1E"/>
            </PanelContainer.PanelOverride>
            <ScrollContainer VerticalExpand="True" HScrollEnabled="False">
                <BoxContainer Name="EmployeeList" Orientation="Vertical" Margin="2 2"/>
            </ScrollContainer>
        </PanelContainer>

        <!-- Footer with NT Logo -->
        <BoxContainer Orientation="Vertical" VerticalAlignment="Bottom">
            <PanelContainer StyleClasses="LowDivider" />
            <BoxContainer Orientation="Horizontal" Margin="12 0 6 2" VerticalAlignment="Bottom">
                <Label Text="{Loc 'capibara-salary-console-flavor-left'}"
                       StyleClasses="WindowFooterText" />
                <Label Text="{Loc 'capibara-salary-console-flavor-right'}"
                       StyleClasses="WindowFooterText"
                       HorizontalAlignment="Right" HorizontalExpand="True"
                       Margin="0 0 4 0" />
                <TextureRect StyleClasses="NTLogoDark"
                             Stretch="KeepAspectCentered"
                             VerticalAlignment="Center"
                             HorizontalAlignment="Right"
                             SetSize="19 19"/>
            </BoxContainer>
        </BoxContainer>

    </BoxContainer>
</controls:FancyWindow>
